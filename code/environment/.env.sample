# 본 도서 실습용 환경 변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 본인 경로에 맞게 값 수정.

# ── 데이터 루트 (대용량 데이터셋 저장 위치) ──
DATA_DIR=/data

# ── 데이터셋별 경로 (장별 사용처 명시) ──
NUSCENES_ROOT=${DATA_DIR}/nuscenes-mini      # ch06 Occupancy, ch25 Mini Occupancy
BDD100K_ROOT=${DATA_DIR}/bdd100k             # ch24 Mini HydraNet
WAYMO_ROOT=${DATA_DIR}/waymo-open-motion     # ch09 Prediction (선택)
CARLA_ROOT=${DATA_DIR}/carla                 # ch14 Simulation

# ── 학습 결과 ──
WEIGHTS_DIR=${DATA_DIR}/weights              # 모델 체크포인트
LOG_DIR=${DATA_DIR}/runs                     # TensorBoard / Wandb 로컬 로그
CACHE_DIR=${DATA_DIR}/cache                  # 전처리 캐시

# ── 학습 설정 ──
NUM_WORKERS=8                                # DataLoader workers
BATCH_SIZE=32                                # 단일 GPU 기준 기본값

# ── 외부 서비스 (선택) ──
# WANDB_API_KEY=
# WANDB_PROJECT=physical-ai-book
# HF_TOKEN=                                  # Hugging Face (ch22 OpenVLA)
